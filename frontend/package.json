{
  "name": "moltbot-frontend",
  "version": "1.0.0",
  "private": true,
  "main": "src/main.js",
  "dependencies": {
    "axios": "^1.15.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-scripts": "5.0.1",
    "three": "^0.160.0",
    "gsap": "^3.12.5"
  },
  "scripts": {
    "start": "react-scripts start",
    "electron": "electron .",
    "build": "react-scripts build",
    "dist": "npm run build && electron-builder"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.moltbot.ai",
    "files": [
      "build/**/*",
      "src/main.js"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/server",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "dist"
    }
  }
}
